{
  "name": "mcpkit",
  "version": "0.1.0",
  "description": "MCP Server Configuration Manager - CLI tool to manage .mcp.json files",
  "main": "dist/index.js",
  "bin": {
    "mcpkit": "./dist/index.js"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "tsc",
    "build:binary": "bun build --compile ./src/index.ts --outfile mcpkit",
    "dev": "tsc && node dist/index.js",
    "prepublishOnly": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tk-425/mcpkit-cli.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli",
    "configuration",
    "manager"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/tk-425/mcpkit-cli/issues"
  },
  "homepage": "https://github.com/tk-425/mcpkit-cli#readme",
  "dependencies": {
    "@inquirer/prompts": "^8.0.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
